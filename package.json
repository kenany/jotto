{
  "name": "jotto",
  "version": "0.0.0-semantic-release",
  "description": "Jotto solver.",
  "keywords": [
    "jotto"
  ],
  "license": "MIT",
  "author": "Kenan Yildirim <kenan@kenany.me> (https://kenany.me/)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kenany/jotto.git"
  },
  "type": "commonjs",
  "types": "dist/index.d.cts",
  "main": "dist/index.cjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./*.mjs": {
      "default": "./dist/*.mjs"
    },
    "./*.cjs": {
      "default": "./dist/*.cjs"
    },
    "./*": {
      "import": "./dist/*.mjs",
      "require": "./dist/*.cjs"
    }
  },
  "bin": {
    "jotto": "dist/cli.cjs"
  },
  "files": [
    "dist",
    "usage.txt",
    "LICENSE.txt"
  ],
  "engines": {
    "node": "22 || 24 || >=26"
  },
  "scripts": {
    "build": "tsdown && tsc --noEmit",
    "lint": "biome check",
    "test": "vitest run",
    "publint": "publint --strict",
    "prepare": "pnpm build"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "graceful-fs": "^4.2.11",
    "humanize-number": "^0.0.2",
    "jots": "^5.0.0",
    "minimist": "^1.2.8",
    "no-repeated-letters": "^6.0.0",
    "printf": "^0.6.1",
    "sowpods-five": "^3.0.0",
    "sowpods-six": "^3.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@containerbase/semantic-release-pnpm": "1.4.1",
    "@kenan/biome-config": "1.0.6",
    "@types/graceful-fs": "4.1.9",
    "@types/minimist": "1.2.5",
    "@types/node": "25.9.2",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "publint": "0.3.21",
    "semantic-release": "25.0.3",
    "tsdown": "0.22.2",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
